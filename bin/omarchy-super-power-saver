#!/bin/bash

# Super Power Saver — a 4th power mode layered on top of power-profiles-daemon's
# power-saver, for maximum battery life. Managed by ~/.config/omarchy/extensions/menu.sh.
#
# Usage: omarchy-super-power-saver on|off|toggle|status|boot-cleanup
#
# User-level:  ppd power-saver, wifi powersave (prior state restored), bluetooth
#              rfkill, drift-watcher (~60s, sysfs reads only — no D-Bus/sudo
#              unless drift or an AC transition is seen). The mode PERSISTS on
#              AC (no auto-exit) and self-defends against udev/ppd profile
#              resets on plug/unplug.
# Root-level (via sudoers-whitelisted helper, see omarchy-super-power-saver-setup, v4):
#              platform_profile=quiet, thermald stopped, EPB=15, RAPL PL1=10W
#              tau 8s / PL2=15W / PL4=25W (MSR+MMIO), pcie_aspm=powersupersave,
#              uncore freq floor, render-GT capped to efficient freq (media GT
#              left SLPC-managed for video decode), SLPC power_saving profile
#              (gt0+gt1), LP-E consolidation: P-cores 1-5 AND E-cores 6-13
#              consolidation OFF by default since the thorough A/B 2026-07-16
#              (all-cores-free tied the best pin on energy at stock-level
#              responsiveness); offlining/pinning/IRQ-steering remain
#              conf-driven variants (SPS_ONLINE_CPUS/SPS_ALLOWED_CPUS/
#              SPS_IRQ_STEER), PSR2
#              assert, fingerprint autosuspend, snd_hda power_save 1s,
#              snapper-timeline.timer paused, nmi_watchdog=0, writeback 60s.
# Deliberately untouched: Hyprland animations/blur/shadows (identical in ALL
#              modes — the v3 toggle was removed 2026-07-08 by request; off
#              still cleans up a legacy toggle file), keyboard backlight
#              (custom tracker setup), USB autosuspend policy (fingerprint
#              device is the one scoped exception, via the root helper), audio
#              power_save policy outside the mode, screen brightness (measured
#              <1W across the range), screensaver + idle-lock chain (stock in
#              all modes, incl. this one).
#
# Scope guarantee: everything is applied on 'on' and restored on 'off'. State
# that persists across reboots (bluetooth rfkill via systemd-rfkill, the
# screensaver-off flag, the legacy hypr toggle conf) is restored even from a
# stale (pre-reboot) state file; 'boot-cleanup' (run from hypr autostart)
# handles a reboot that happened while the mode was on. If the user-side state
# file is lost while the root half is still applied, 'off' (and the watcher)
# fall back to the root /run state to restore anyway.

set -u

STATE_DIR="$HOME/.local/state/omarchy-super-power-saver"
STATE_FILE="$STATE_DIR/state"
# Root helper's live state (world-readable existence check; content is root's).
RUN_STATE_ROOT=/run/omarchy-super-power-saver.state
# Legacy (v3): the mode used to disable animations/blur/shadows via this file.
# v4 never creates it, but off/boot-cleanup still remove a leftover.
HYPR_TOGGLE="$HOME/.local/state/omarchy/toggles/hypr/super-power-saver.conf"
SS_FLAG="$HOME/.local/state/omarchy/toggles/screensaver-off"
HELPER=/usr/local/bin/omarchy-super-power-saver-helper
BACKLIGHT=/sys/class/backlight/intel_backlight
WATCH_UNIT=omarchy-super-power-saver-watch
SELF="$HOME/.local/bin/omarchy-super-power-saver"

boot_id() { cat /proc/sys/kernel/random/boot_id; }

read_state() { grep "^$1=" "$STATE_FILE" 2>/dev/null | cut -d= -f2; }

state_stale() {
  [[ -f $STATE_FILE ]] || return 0
  [[ $(read_state boot_id) != "$(boot_id)" ]]
}

is_on() {
  [[ -f $STATE_FILE ]] && ! state_stale
}

# Undo the changes that persist across reboots (rfkill state is re-applied at
# boot by systemd-rfkill; the flag files live on disk). Safe to call with a
# stale state file — that is exactly its job.
restore_persistent_from_state() {
  [[ -f $STATE_FILE ]] || return 0
  [[ $(read_state bt_was_blocked) == no ]] && rfkill unblock bluetooth 2>/dev/null
  if grep -q '^screensaver_disabled_by_us=yes' "$STATE_FILE"; then
    rm -f "$SS_FLAG"
  fi
  rm -f "$HYPR_TOGGLE"
}

# One string that changes whenever any power supply's online state flips —
# plug/unplug detection without udev or D-Bus.
ac_fingerprint() {
  local s="" p
  for p in /sys/class/power_supply/*/online; do
    [[ -r $p ]] && s+=$(cat "$p" 2>/dev/null)
  done
  echo "$s"
}

# Hand an 'off' to a detached unit. The watcher must NEVER run do_off in its
# own process: do_off stops the watcher unit, which would kill the restore
# mid-flight (the v3 AC-auto-exit bug class).
detached_off() {
  systemd-run --user --collect --unit="$WATCH_UNIT-reconcile" \
    "$SELF" off reconcile 2>/dev/null
}

# Watcher body (internal, run inside the transient unit): the mode PERSISTS on
# AC (user preference 2026-07-08 — no auto-exit). When AC is plugged/unplugged,
# omarchy's udev rule resets the ppd profile and the EC rewrites MMIO RAPL; ppd
# rewrites EPP/EPB on any profile change. Instead of blindly running the root
# helper every tick (v3), poll cheap user-readable sysfs and only escalate to
# `sudo helper reassert` on drift or an AC transition. MSR RAPL (not MMIO) is
# the authoritative drift signal — the EC only rewrites MMIO, so EC noise can't
# cause reassert storms. Expectations start from the state file's observed
# post-apply values and are re-observed after every successful reassert (the
# /etc conf can change PL1 between on and reassert — frozen expectations would
# storm).
do_watch_loop() {
  # Nothing to defend when the root half never applied (setup not run).
  [[ $(read_state root_applied) == yes ]] || exit 0
  local exp_pl1 exp_cpu6 exp_pin last cur drift
  exp_pl1=$(read_state watch_pl1); : "${exp_pl1:=10000000}"
  exp_cpu6=$(read_state watch_cpu6); : "${exp_cpu6:=0}"
  exp_pin=$(read_state watch_pin) # may be empty (unpinned variant) — stable
  last=$(ac_fingerprint)
  while true; do
    sleep 60
    if ! is_on; then
      # User state gone. If the root knobs are still applied, finish the off
      # via the lost-state path in do_off (detached — see detached_off).
      [[ -f $RUN_STATE_ROOT ]] && detached_off
      exit 0
    fi
    drift=0
    [[ $(cat /sys/devices/system/cpu/cpu0/cpufreq/energy_performance_preference 2>/dev/null) == power ]] || drift=1
    [[ $(cat /sys/firmware/acpi/platform_profile 2>/dev/null) == quiet ]] || drift=1
    [[ $(cat /sys/class/powercap/intel-rapl:0/constraint_0_power_limit_uw 2>/dev/null) == "$exp_pl1" ]] || drift=1
    [[ $(cat /sys/devices/system/cpu/cpu6/online 2>/dev/null) == "$exp_cpu6" ]] || drift=1
    # cgroup pin: a dropped AllowedCPUs unconfines userspace with none of the
    # other canaries moving (found in audit 2026-07-08)
    [[ $(cat /sys/fs/cgroup/user.slice/cpuset.cpus 2>/dev/null) == "$exp_pin" ]] || drift=1
    cur=$(ac_fingerprint)
    if [[ $drift == 1 || $cur != "$last" ]]; then
      if [[ ! -f $RUN_STATE_ROOT ]]; then
        # Root state lost while we think the mode is on: reassert would no-op
        # forever (livelock) — reconcile to off instead.
        detached_off
        exit 0
      fi
      # 180s > helper worst case (20s flock + serial 25s systemctl timeouts)
      if [[ -x $HELPER ]] && timeout 180 sudo -n "$HELPER" reassert 2>/dev/null; then
        exp_pl1=$(cat /sys/class/powercap/intel-rapl:0/constraint_0_power_limit_uw 2>/dev/null)
        exp_cpu6=$(cat /sys/devices/system/cpu/cpu6/online 2>/dev/null)
        exp_pin=$(cat /sys/fs/cgroup/user.slice/cpuset.cpus 2>/dev/null)
        # persist: a revived watcher (re-login boot-cleanup) must inherit the
        # CURRENT expectations, not the on-time ones
        sed -i "s/^watch_pl1=.*/watch_pl1=$exp_pl1/;s/^watch_cpu6=.*/watch_cpu6=$exp_cpu6/;s/^watch_pin=.*/watch_pin=$exp_pin/" "$STATE_FILE" 2>/dev/null
      fi
    fi
    last=$cur
  done
}

start_watcher() {
  # Stop-then-start: a leftover watcher from a previous session would keep
  # stale expectations; systemd-run also refuses duplicate unit names.
  systemctl --user stop "$WATCH_UNIT.service" 2>/dev/null
  systemd-run --user --collect --unit="$WATCH_UNIT" "$SELF" watch-loop 2>/dev/null ||
    echo "super-power-saver: drift watcher failed to start; mode undefended until next boot-cleanup" >&2
}

stop_watcher() {
  systemctl --user stop "$WATCH_UNIT.service" 2>/dev/null
}

root_helper() {
  # 300s > the helper's worst-case internal budget (flock 20s + a dozen serial
  # 25s systemctl/ppd timeouts) — a shorter caller timeout would SIGTERM the
  # helper mid-apply in exactly the wedged-D-Bus case those timeouts exist for.
  if [[ -x $HELPER ]] && timeout 300 sudo -n "$HELPER" "$1" 2>/dev/null; then
    return 0
  fi
  notify-send -u normal "Super Power Saver" \
    "CPU/RAPL/PCIe limits skipped — run omarchy-super-power-saver-setup once to enable them." 2>/dev/null
  return 1
}

on_ac() {
  local ps t
  for ps in /sys/class/power_supply/*; do
    [[ -r $ps/online && -r $ps/type ]] || continue
    t=$(cat "$ps/type")
    [[ ( $t == Mains || $t == USB ) && $(cat "$ps/online") == 1 ]] && return 0
  done
  return 1
}

wifi_powersave_state() { # -> on|off|"" (last wireless iface wins; one on laptops)
  local i
  for i in /sys/class/net/*/wireless; do
    [[ -d ${i%/wireless} ]] || continue
    iw dev "$(basename "${i%/wireless}")" get power_save 2>/dev/null |
      grep -oE 'on|off' | head -1
  done | tail -1
}

do_on() {
  is_on && exit 0
  # Root half still applied but user state lost/stale: reconcile to stock
  # FIRST — snapshotting now would record the MODE's own values (profile
  # power-saver, BT blocked, wifi powersave) as the "prior" state, and the
  # eventual off would restore those instead of the user's real settings.
  if [[ -f $RUN_STATE_ROOT ]]; then
    stop_watcher
    if [[ -x $HELPER ]] && ! timeout 300 sudo -n "$HELPER" off 2>/dev/null; then
      notify-send -u critical "Super Power Saver" \
        "Stale root state could not be cleared — not enabling. Run 'omarchy-super-power-saver off' and retry." 2>/dev/null
      return 1
    fi
    # profile back to stock semantics before it gets snapshotted as "prior"
    omarchy-powerprofiles-set 2>/dev/null
  fi
  # A stale state file means we rebooted while the mode was on: clean up the
  # persistent leftovers BEFORE snapshotting, or they'd become the "baseline".
  # A removed legacy toggle needs a reload, or animations stay killed all
  # session (they must be identical in all modes).
  if [[ -f $STATE_FILE ]] && state_stale; then
    local had_legacy_toggle=""
    [[ -f $HYPR_TOGGLE ]] && had_legacy_toggle=yes
    restore_persistent_from_state
    rm -f "$STATE_FILE"
    [[ $had_legacy_toggle == yes ]] && hyprctl reload >/dev/null 2>&1
  fi
  mkdir -p "$STATE_DIR"

  # Record prior state and PERSIST it before making any change (a crash
  # between a change and its record would leak the change — bug-hunt finding).
  local bt_present="" bt_was_blocked=""
  if command -v rfkill >/dev/null && rfkill list bluetooth 2>/dev/null | grep -q .; then
    bt_present=yes
    rfkill list bluetooth | grep -q "Soft blocked: yes" && bt_was_blocked=yes || bt_was_blocked=no
  fi

  # NOTE: the screensaver and idle-lock chain are deliberately left stock in
  # this mode (user requirement 2026-07-08) — no screensaver disable, no DPMS
  # meddling. The screensaver_disabled_by_us handling in
  # restore_persistent_from_state stays only to clean up old state files.
  {
    echo "v=4"
    echo "boot_id=$(boot_id)"
    echo "prev_profile=$(powerprofilesctl get 2>/dev/null)"
    echo "was_on_ac=$(on_ac && echo yes || echo no)"
    echo "wifi_powersave_was=$(wifi_powersave_state)"
    echo "bt_was_blocked=$bt_was_blocked"
  } >"$STATE_FILE"

  [[ $bt_present == yes ]] && rfkill block bluetooth 2>/dev/null

  # Base profile first (EPP=power + platform quiet via ppd); helper then layers
  # CPU/RAPL/PCIe/GPU/IRQ/cgroup/PSR knobs on top.
  powerprofilesctl set power-saver 2>/dev/null
  local root_applied=yes
  root_helper on || root_applied=no

  # Watcher expectations = OBSERVED post-apply state, not hardcoded targets:
  # correct under the /etc conf PL1 A/B variant and under a stale v3 helper
  # (where cpu6 stays online — a hardcoded 0 would reassert forever).
  {
    echo "root_applied=$root_applied"
    echo "watch_pl1=$(cat /sys/class/powercap/intel-rapl:0/constraint_0_power_limit_uw 2>/dev/null)"
    echo "watch_cpu6=$(cat /sys/devices/system/cpu/cpu6/online 2>/dev/null)"
    echo "watch_pin=$(cat /sys/fs/cgroup/user.slice/cpuset.cpus 2>/dev/null)"
  } >>"$STATE_FILE"

  omarchy-wifi-powersave on 2>/dev/null

  # Without the root half there is nothing for the watcher to defend.
  [[ $root_applied == yes ]] && start_watcher
  # No mode-change notifications (user preference 2026-07-08); the root_helper
  # failure notification is the only exception.
  return 0
}

do_off() {
  local reason="${1:-manual}"

  # A queued reconcile (spawned for a LOST user state) that lost the flock
  # race to a manual 'on' must not tear down the freshly enabled mode.
  if [[ $reason == reconcile ]] && is_on; then
    return 0
  fi

  if [[ ! -f $STATE_FILE ]]; then
    if [[ -f $RUN_STATE_ROOT ]]; then
      # User state lost while the root half is still applied: the helper holds
      # the pristine baseline (or falls back to the /etc defaults cache) — use
      # it. prev-profile/wifi snapshots are gone; stock semantics for those.
      # A FAILED root restore (helper exit 75 on lock timeout, etc.) must not
      # read as success: keep /run state for a retried off and say so.
      stop_watcher
      if [[ -x $HELPER ]] && ! timeout 300 sudo -n "$HELPER" off 2>/dev/null; then
        notify-send -u critical "Super Power Saver" \
          "Root restore FAILED — CPU/RAPL/IRQ limits may still be active. Run 'omarchy-super-power-saver off' again." 2>/dev/null
        return 1
      fi
      omarchy-powerprofiles-set 2>/dev/null
      return 0
    fi
    if [[ -f $HYPR_TOGGLE ]]; then
      # Orphaned legacy v3 toggle on an otherwise-off system: clean it up
      # WITHOUT invoking the helper (its no-state restore is a sledgehammer
      # that must not run against a stock system).
      rm -f "$HYPR_TOGGLE"
      hyprctl reload >/dev/null 2>&1
      return 0
    fi
    echo "already off"
    return 0
  fi

  stop_watcher

  local was_fresh=""
  is_on && was_fresh=yes

  # Legacy v3 toggle: if present, its removal must be followed by a reload;
  # a normal v4 off never touches Hyprland at all.
  local had_legacy_toggle=""
  [[ -f $HYPR_TOGGLE ]] && had_legacy_toggle=yes

  # Root knobs FIRST (the cgroup unpin at the top of the helper's restore
  # frees this script and everything it spawns from the 2x2.5GHz LP-E
  # confinement) — but ONLY for a same-boot state: root knobs reset at reboot,
  # and a stale-state off must not fire the helper's no-state sledgehammer
  # restore at a freshly-booted stock system. A failed root restore keeps the
  # state file so the mode still reads 'on' and a later off can retry.
  # Only call the helper when the root half is actually live (root_applied=yes
  # or /run state present): with sudoers missing and nothing applied, a failed
  # helper call would otherwise keep the state file forever ('on' in the menu
  # with no way off short of a reboot).
  local root_off_ok=yes root_live=no
  [[ $(read_state root_applied) == yes || -f $RUN_STATE_ROOT ]] && root_live=yes
  if [[ $was_fresh == yes && $root_live == yes && -x $HELPER ]]; then
    if ! timeout 300 sudo -n "$HELPER" off 2>/dev/null; then
      root_off_ok=no
      notify-send -u critical "Super Power Saver" \
        "Root restore FAILED — CPU/RAPL/IRQ limits may still be active. Re-run omarchy-super-power-saver-setup, then 'omarchy-super-power-saver off' again." 2>/dev/null
    fi
  fi

  # Brightness restore: migration path for state files from the old version
  local prev_brightness
  prev_brightness=$(read_state prev_brightness)
  if [[ -n $prev_brightness && -r $BACKLIGHT/brightness && $was_fresh == yes ]]; then
    brightnessctl -d intel_backlight set "$prev_brightness" >/dev/null 2>&1
  fi
  # BT / screensaver / legacy hypr-toggle persist across reboots: restore
  # even from a stale state file.
  restore_persistent_from_state

  rm -f "$HYPR_TOGGLE"
  [[ $had_legacy_toggle == yes ]] && hyprctl reload >/dev/null 2>&1

  # Profile: restore what the user had before 'on' (stock semantics: a manual
  # selection persists) — but only if the AC state hasn't changed since 'on';
  # on a plug/unplug in between, stock transition semantics
  # (omarchy-powerprofiles-set) win. v3-era state files lack was_on_ac and
  # fall through to the stock path.
  local prev_profile ac_now
  prev_profile=$(read_state prev_profile)
  ac_now=$(on_ac && echo yes || echo no)
  if [[ $reason == manual && $was_fresh == yes && -n $prev_profile &&
        $ac_now == "$(read_state was_on_ac)" ]]; then
    powerprofilesctl set "$prev_profile" 2>/dev/null
  else
    omarchy-powerprofiles-set 2>/dev/null
  fi

  # Wifi powersave: exact snapshot restore; AC heuristic only as the fallback
  # for v3-era state files that lack the key.
  local wifi_prev
  wifi_prev=$(read_state wifi_powersave_was)
  if [[ $was_fresh == yes && ( $wifi_prev == on || $wifi_prev == off ) ]]; then
    omarchy-wifi-powersave "$wifi_prev" 2>/dev/null
  elif omarchy-ac-present 2>/dev/null; then
    omarchy-wifi-powersave off 2>/dev/null
  fi

  [[ $root_off_ok == yes ]] && rm -f "$STATE_FILE"
  # No mode-change notifications (user preference 2026-07-08).
}

# Run from hypr autostart: if we rebooted while the mode was on, silently
# clean the persistent leftovers (sysfs knobs reset at boot on their own).
# If instead this is a same-boot re-login while the mode is ON, the watcher
# unit died with the old session — revive it and re-pin the knobs, otherwise
# drift would go undefended for the rest of the session (bug-hunt finding).
do_boot_cleanup() {
  if [[ -f $STATE_FILE ]] && state_stale; then
    local had_legacy_toggle=""
    [[ -f $HYPR_TOGGLE ]] && had_legacy_toggle=yes
    restore_persistent_from_state
    rm -f "$STATE_FILE"
    [[ $had_legacy_toggle == yes ]] && hyprctl reload >/dev/null 2>&1
  elif is_on && ! systemctl --user is-active --quiet "$WATCH_UNIT.service"; then
    if [[ -f $RUN_STATE_ROOT ]]; then
      [[ -x $HELPER ]] && timeout 180 sudo -n "$HELPER" reassert 2>/dev/null
      start_watcher
    elif [[ $(read_state root_applied) == yes ]]; then
      # 'off' crashed between the root restore and the user-side cleanup (or
      # /run state was lost): the root side is already stock — finish the
      # interrupted off instead of reviving a half-on mode.
      do_off auto
    fi
    # else: setup was never run for this activation — nothing to revive.
  elif [[ ! -f $STATE_FILE && -f $RUN_STATE_ROOT ]]; then
    # User state lost while root knobs are still applied and no watcher is
    # around to reconcile: finish the off here (same-boot re-login case).
    do_off auto
  elif [[ ! -f $STATE_FILE && -f $HYPR_TOGGLE ]]; then
    # Orphaned legacy v3 toggle, no state at all: without this branch it would
    # silently degrade the UI every boot, forever.
    rm -f "$HYPR_TOGGLE"
    hyprctl reload >/dev/null 2>&1
  fi
}

# Serialize the mutating verbs (a double-tap toggle raced on vs off: knobs
# applied while status said off). watch-loop is deliberately excluded — it
# runs forever and its escalations are serialized by the helper's /run flock;
# status stays lock-free (read-only).
case "${1:-status}" in
on | off | toggle | boot-cleanup)
  mkdir -p "$STATE_DIR"
  exec 8>"$STATE_DIR/.lock"
  flock 8
  ;;
esac

case "${1:-status}" in
on) do_on ;;
off) do_off "${2:-manual}" ;;
toggle) if is_on; then do_off; else do_on; fi ;;
status) if is_on; then echo on; else echo off; fi ;;
boot-cleanup) do_boot_cleanup ;;
watch-loop) do_watch_loop ;; # internal: body of the transient watcher unit
*)
  echo "Usage: omarchy-super-power-saver on|off|toggle|status|boot-cleanup" >&2
  exit 1
  ;;
esac
